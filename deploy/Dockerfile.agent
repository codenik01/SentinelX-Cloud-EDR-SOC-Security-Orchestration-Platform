# Stage 1: Build the Go binary
FROM golang:1.21-alpine AS builder

WORKDIR /app

COPY go.mod ./
RUN go mod download

COPY *.go ./

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o sentinelx-agent .

# Stage 2: Minimal runtime image
FROM alpine:3.19

WORKDIR /root/

RUN apk --no-cache add ca-certificates

COPY --from=builder /app/sentinelx-agent .

# Run the agent daemon
CMD ["./sentinelx-agent"]
